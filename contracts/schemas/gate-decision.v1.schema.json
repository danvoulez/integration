{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logline.world/schemas/gate-decision.v1.schema.json",
  "title": "GateDecision.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "decision", "policy", "applied_rules", "derived_from"],
  "properties": {
    "version": {
      "type": "string",
      "const": "gate-decision.v1"
    },
    "decision": {
      "type": "string",
      "enum": ["YES", "NO", "HUMAN", "CLOUD"]
    },
    "policy": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "applied_rules": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "result"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 32
          },
          "result": {
            "type": "string",
            "enum": ["pass", "fail", "skip"]
          },
          "note": {
            "type": "string",
            "maxLength": 400
          }
        }
      }
    },
    "derived_from": {
      "type": "object",
      "additionalProperties": false,
      "required": ["opinion_event_id", "trace_id"],
      "properties": {
        "opinion_event_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "trace_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        }
      }
    }
  }
}
