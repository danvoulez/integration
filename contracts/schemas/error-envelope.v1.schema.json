{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logline.world/schemas/error-envelope.v1.schema.json",
  "title": "ErrorEnvelope.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["output_schema", "error"],
  "properties": {
    "request_id": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 128
    },
    "output_schema": {
      "type": "string",
      "const": "https://logline.world/schemas/error-envelope.v1.schema.json"
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["message", "type"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": ["object", "array", "string", "number", "boolean", "null"]
        }
      }
    }
  }
}
