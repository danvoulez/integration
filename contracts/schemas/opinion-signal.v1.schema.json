{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logline.world/schemas/opinion-signal.v1.schema.json",
  "title": "OpinionSignal.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "output_schema",
    "version",
    "signal",
    "confidence",
    "reason_codes",
    "evidence"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "output_schema": {
      "type": "string",
      "const": "https://logline.world/schemas/opinion-signal.v1.schema.json"
    },
    "version": {
      "type": "string",
      "const": "opinion-signal.v1"
    },
    "signal": {
      "type": "string",
      "enum": ["ALLOW", "DENY", "ESCALATE"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      }
    },
    "evidence": {
      "type": "array",
      "maxItems": 16,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "ref"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["file", "chunk", "event", "trace", "metric", "url"]
          },
          "ref": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          },
          "quote": {
            "type": "string",
            "maxLength": 300
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "proposal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["next", "payload"],
      "properties": {
        "next": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          }
        },
        "payload": {
          "type": "object"
        }
      }
    },
    "debug_note": {
      "type": "string",
      "maxLength": 2000
    }
  }
}
