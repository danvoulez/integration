{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logline.world/schemas/llm-gateway.chat-response.v1.schema.json",
  "title": "LlmGatewayChatResponse.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "output_schema",
    "id",
    "object",
    "created",
    "model",
    "choices",
    "usage",
    "_lab"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "output_schema": {
      "type": "string",
      "const": "https://logline.world/schemas/llm-gateway.chat-response.v1.schema.json"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "object": {
      "type": "string",
      "const": "chat.completion"
    },
    "created": {
      "type": "integer"
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "choices": {
      "type": "array",
      "minItems": 1
    },
    "usage": {
      "type": "object",
      "required": ["prompt_tokens", "completion_tokens", "total_tokens"],
      "properties": {
        "prompt_tokens": { "type": "integer" },
        "completion_tokens": { "type": "integer" },
        "total_tokens": { "type": "integer" }
      }
    },
    "_lab": {
      "type": "object",
      "required": [
        "route",
        "upstream_url",
        "model_used",
        "mode_used",
        "task_class",
        "decision_path",
        "cost_tier"
      ],
      "properties": {
        "route": { "type": "string" },
        "upstream_url": { "type": "string" },
        "model_used": { "type": "string" },
        "mode_used": { "type": "string" },
        "task_class": { "type": "string" },
        "decision_path": {
          "type": "array",
          "items": { "type": "string" }
        },
        "cost_tier": { "type": "string" }
      }
    }
  }
}
