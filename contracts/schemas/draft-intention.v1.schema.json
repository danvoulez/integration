{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logline.world/schemas/draft-intention.v1.schema.json",
  "title": "DraftIntention.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "output_schema",
    "version",
    "draft_intention_id",
    "created_at",
    "author",
    "source",
    "ast",
    "diagnostics",
    "questions"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "output_schema": {
      "type": "string",
      "const": "https://logline.world/schemas/draft-intention.v1.schema.json"
    },
    "version": {
      "type": "string",
      "const": "draft-intention.v1"
    },
    "draft_intention_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "author": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["human", "service", "system"]
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["ui", "linear", "api", "fuel_diff"]
        },
        "ref": {
          "type": "string",
          "maxLength": 256
        }
      }
    },
    "ast": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "title",
        "goal",
        "scope",
        "acceptance_criteria",
        "constraints",
        "rollback"
      ],
      "properties": {
        "version": {
          "type": "string",
          "const": "intention.ast.v1"
        },
        "title": {
          "type": "string",
          "minLength": 3,
          "maxLength": 140
        },
        "goal": {
          "type": "string",
          "minLength": 10,
          "maxLength": 1200
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["in", "out"],
          "properties": {
            "in": {
              "type": "array",
              "minItems": 1,
              "maxItems": 20,
              "items": {
                "type": "string",
                "minLength": 2,
                "maxLength": 200
              }
            },
            "out": {
              "type": "array",
              "minItems": 1,
              "maxItems": 20,
              "items": {
                "type": "string",
                "minLength": 2,
                "maxLength": 200
              }
            }
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "items": {
            "type": "string",
            "minLength": 8,
            "maxLength": 240
          }
        },
        "constraints": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "risk_tier",
            "max_files_changed",
            "max_diff_lines",
            "rollback_required",
            "requires_human_review"
          ],
          "properties": {
            "risk_tier": {
              "type": "string",
              "enum": ["LOW", "MED", "HIGH"]
            },
            "max_files_changed": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            },
            "max_diff_lines": {
              "type": "integer",
              "minimum": 1,
              "maximum": 20000
            },
            "rollback_required": {
              "type": "boolean"
            },
            "requires_human_review": {
              "type": "boolean"
            }
          }
        },
        "rollback": {
          "$ref": "rollback-plan.v1.schema.json"
        }
      }
    },
    "diagnostics": {
      "type": "array",
      "maxItems": 25,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "code", "message"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["ERROR", "WARN", "INFO"]
          },
          "code": {
            "type": "string",
            "minLength": 3,
            "maxLength": 32
          },
          "message": {
            "type": "string",
            "minLength": 3,
            "maxLength": 400
          },
          "fields": {
            "type": "array",
            "maxItems": 8,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            }
          },
          "suggestion": {
            "type": "string",
            "maxLength": 400
          }
        }
      }
    },
    "questions": {
      "type": "array",
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "question", "field_target"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 3,
            "maxLength": 16
          },
          "question": {
            "type": "string",
            "minLength": 5,
            "maxLength": 300
          },
          "field_target": {
            "type": "string",
            "minLength": 3,
            "maxLength": 64
          },
          "choices": {
            "type": "array",
            "maxItems": 12,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 80
            }
          }
        }
      }
    }
  }
}
