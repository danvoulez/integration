{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logline.world/schemas/rollback-plan.v1.schema.json",
  "title": "RollbackPlan.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "strategy", "steps", "verification"],
  "properties": {
    "version": {
      "type": "string",
      "const": "rollback-plan.v1"
    },
    "strategy": {
      "type": "string",
      "enum": ["REVERT_PR", "FEATURE_FLAG", "CONFIG_TOGGLE", "ROLLBACK_SCRIPT"]
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "string",
        "minLength": 3,
        "maxLength": 240
      }
    },
    "verification": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "string",
        "minLength": 3,
        "maxLength": 240
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["pr", "deploy", "config", "flag", "script"]
        },
        "ref": {
          "type": "string",
          "maxLength": 256
        }
      }
    },
    "time_lock_minutes": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10080
    },
    "requires_two_person_confirm": {
      "type": "boolean",
      "default": false
    }
  }
}
