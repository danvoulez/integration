LLM_LOCAL_ADAPTIVE_EMERGENCY_NUM_CTX_CAP=2048
LLM_LOCAL_ADAPTIVE_EMERGENCY_NUM_BATCH_CAP=128
LLM_LOCAL_DEFAULT_MAX_TOKENS=768
