{
  "schema_version": "1.0",
  "workspace": {
    "name": "LLM Gateway",
    "id": "llm-gateway",
    "default_branch": "main"
  },
  "constitution": {
    "canon_docs": [
      "README.md"
    ],
    "adrs": [],
    "invariants": [
      "README.md"
    ],
    "roadmap": [],
    "runbooks": []
  },
  "contracts": {
    "schemas_paths": [
      "schemas"
    ],
    "openapi_paths": [
      "openapi.yaml"
    ],
    "events_registry": ""
  },
  "policy": {
    "config_paths": [],
    "validation_command": "cargo check"
  },
  "gates": {
    "gate0": {
      "commands": [
        "cargo check",
        "cargo test"
      ]
    },
    "per_area": {
      "contracts": [
        "cargo check"
      ],
      "policy": [
        "cargo check"
      ],
      "tests": [
        "cargo test"
      ],
      "types": [
        "cargo check"
      ],
      "security": []
    }
  },
  "inputs": {
    "primary": "linear",
    "linear": {
      "endpoint": "https://api.linear.app/graphql",
      "auth": {
        "token_env": "LINEAR_API_KEY"
      },
      "claim": {
        "strategy": "label",
        "label": "agent:runner",
        "assignee_is_bot_ok": true
      },
      "filters": {
        "team_key": "",
        "project_name": "",
        "include_labels": [],
        "exclude_labels": [],
        "min_priority": 0,
        "max_priority": 4
      },
      "polling": {
        "interval_seconds": 90,
        "page_size": 50
      }
    }
  },
  "execution": {
    "work_branch_prefix": "runner/",
    "max_files_changed": 60,
    "max_diff_lines": 1200,
    "require_how_to_test": true,
    "require_acceptance": true
  }
}
