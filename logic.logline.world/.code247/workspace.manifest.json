{
  "schema_version": "1.0",
  "workspace": {
    "name": "Logic",
    "id": "logic",
    "default_branch": "main"
  },
  "constitution": {
    "canon_docs": [
      "README.md",
      "GENESIS.json"
    ],
    "adrs": [
      "docs"
    ],
    "invariants": [
      "docs"
    ],
    "roadmap": [
      "docs"
    ],
    "runbooks": [
      "supabase"
    ]
  },
  "contracts": {
    "schemas_paths": [
      "schemas"
    ],
    "openapi_paths": [],
    "events_registry": ""
  },
  "policy": {
    "config_paths": [
      "logline.cicd.json"
    ],
    "validation_command": "cargo check --workspace"
  },
  "gates": {
    "gate0": {
      "commands": [
        "cargo check --workspace",
        "cargo test --workspace"
      ]
    },
    "per_area": {
      "contracts": [
        "cargo check --workspace"
      ],
      "policy": [
        "cargo check --workspace"
      ],
      "tests": [
        "cargo test --workspace"
      ],
      "types": [
        "cargo check --workspace"
      ],
      "security": []
    }
  },
  "inputs": {
    "primary": "linear",
    "linear": {
      "endpoint": "https://api.linear.app/graphql",
      "auth": {
        "token_env": "LINEAR_API_KEY"
      },
      "claim": {
        "strategy": "label",
        "label": "agent:runner",
        "assignee_is_bot_ok": true
      },
      "filters": {
        "team_key": "",
        "project_name": "",
        "include_labels": [],
        "exclude_labels": [],
        "min_priority": 0,
        "max_priority": 4
      },
      "polling": {
        "interval_seconds": 90,
        "page_size": 50
      }
    }
  },
  "execution": {
    "work_branch_prefix": "runner/",
    "max_files_changed": 60,
    "max_diff_lines": 1200,
    "require_how_to_test": true,
    "require_acceptance": true
  }
}
