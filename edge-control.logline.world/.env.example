RUST_LOG=info
EDGE_CONTROL_HOST=0.0.0.0
EDGE_CONTROL_PORT=8080
EDGE_CONTROL_POLICY_SET_PATH=../policy/policy-set.v1.1.json

# Supabase (required for Fuel emission / EDGE-004)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
EDGE_CONTROL_DEFAULT_TENANT_ID=
EDGE_CONTROL_DEFAULT_APP_ID=edge-control
EDGE_CONTROL_DEFAULT_USER_ID=edge-control-system

# obs-api ingestion target (optional, for observability sync)
OBS_API_BASE_URL=https://obs-api.logline.world
OBS_API_TOKEN=

# Code247 orchestration target
CODE247_BASE_URL=http://127.0.0.1:4001
CODE247_INTENTIONS_TOKEN=

# Auth mode 1 (preferred): Supabase HS256 JWT verification
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=

# Auth mode 2 (fallback/internal): static bearer token
EDGE_CONTROL_INTERNAL_API_TOKEN=

# Rate limit / idempotency
EDGE_CONTROL_RATE_LIMIT_WINDOW_SECONDS=60
EDGE_CONTROL_RATE_LIMIT_MAX_REQUESTS=120
EDGE_CONTROL_IDEMPOTENCY_TTL_SECONDS=900
