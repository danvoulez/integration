{
  "schema_version": "1.0",
  "workspace": {
    "name": "Code247",
    "id": "code247",
    "default_branch": "main"
  },
  "constitution": {
    "canon_docs": [
      "README.md",
      "CODE247 × VVTV — Integration Contract v1.md",
      "docs/Code247-Linear-Integration.md",
      "docs/Linear-Setup-Runbook.md"
    ],
    "adrs": [],
    "invariants": [
      "Consumo-de-Projetos.md"
    ],
    "roadmap": [
      "Consumo-de-Projetos.md",
      "docs/Linear-Implementation-Checklist.md"
    ],
    "runbooks": [
      "systemd/dual-agents.service",
      "docs/Linear-Setup-Runbook.md"
    ]
  },
  "contracts": {
    "schemas_paths": [
      "schemas"
    ],
    "openapi_paths": [],
    "events_registry": ""
  },
  "policy": {
    "config_paths": [
      "schemas/code247-linear-runtime.extensions.schema.json",
      "docs/linear-tasklist.json"
    ],
    "validation_command": "cargo test"
  },
  "gates": {
    "gate0": {
      "commands": [
        "cargo test",
        "cargo check",
        "./scripts/validate-manifest.sh",
        "./scripts/validate-linear-extensions.sh"
      ]
    },
    "per_area": {
      "contracts": [
        "./scripts/validate-manifest.sh",
        "./scripts/validate-linear-extensions.sh"
      ],
      "policy": [
        "./scripts/validate-manifest.sh",
        "./scripts/validate-linear-extensions.sh"
      ],
      "tests": [
        "cargo test"
      ],
      "types": [
        "cargo check"
      ],
      "security": []
    }
  },
  "inputs": {
    "primary": "linear",
    "linear": {
      "endpoint": "https://api.linear.app/graphql",
      "auth": {
        "token_env": "LINEAR_API_KEY"
      },
      "claim": {
        "strategy": "label",
        "label": "agent:runner",
        "assignee_is_bot_ok": true
      },
      "filters": {
        "team_key": "",
        "project_name": "",
        "include_labels": [],
        "exclude_labels": [],
        "max_priority": 4,
        "min_priority": 0
      },
      "polling": {
        "interval_seconds": 90,
        "page_size": 50
      }
    }
  },
  "execution": {
    "work_branch_prefix": "runner/",
    "max_files_changed": 40,
    "max_diff_lines": 1200,
    "require_how_to_test": true,
    "require_acceptance": true
  },
  "x_linear_oauth": {
    "actor": "app",
    "authorize_url": "https://linear.app/oauth/authorize",
    "token_url": "https://api.linear.app/oauth/token",
    "client_id_env": "LINEAR_CLIENT_ID",
    "client_secret_env": "LINEAR_CLIENT_SECRET",
    "redirect_uri": "https://code247.logline.world/oauth/callback",
    "scopes": [
      "read",
      "write",
      "comments:create",
      "issues:create"
    ]
  },
  "x_linear_webhook": {
    "enabled": true,
    "endpoint_path": "/webhooks/linear",
    "signing_secret_env": "LINEAR_WEBHOOK_SIGNING_SECRET",
    "signature_header": "Linear-Signature",
    "timestamp_field": "webhookTimestamp",
    "max_skew_ms": 60000,
    "delivery_header": "Linear-Delivery",
    "ack_timeout_ms": 5000,
    "resource_types": [
      "Issue",
      "Comment"
    ],
    "dedupe_ttl_hours": 168
  },
  "x_linear_automation": {
    "queue_label": "code247:queue",
    "locked_label": "code247:locked",
    "running_label": "code247:running",
    "needs_human_label": "code247:needs-human",
    "validated_label": "code247:validated",
    "lock_ttl_minutes": 120,
    "start_comment_template": "Code247 run started: run_id={{run_id}}",
    "done_requires_evidence": true
  }
}
